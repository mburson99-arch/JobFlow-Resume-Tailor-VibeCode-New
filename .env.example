# Required for AI resume tailoring.
# Gemini is the primary provider.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_MODEL="gemini-flash-latest"

# Optional fallback provider.
# Used only if Gemini is unavailable and a key is configured.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openrouter/free"

# Google OAuth Web Client ID for direct Gmail API access.
# Add http://localhost:3000 as an authorized JavaScript origin in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_OAUTH_WEB_CLIENT_ID.apps.googleusercontent.com"

# Local app URL used by development and OAuth-related flows.
APP_URL="http://localhost:3000"
